# ============================================================
# 追番向导 · 环境变量示例
# ------------------------------------------------------------
# 将本文件复制为 .env.local（本地）或在部署平台注入同名变量
# 所有带 "必需" 标记的项在生产环境缺失会导致启动或运行时报错
# ============================================================

# ---------- 站点基础 ----------
# 对外访问的完整 URL，用于 OpenGraph、sitemap、robots 拼接绝对地址
# 必需（生产）
NEXT_PUBLIC_SITE_URL=https://zhuifanhub.com

# ---------- 鉴权 ----------
# Session cookie 签名密钥，至少 32 字符随机字符串
# 生成示例: openssl rand -hex 32
# 必需（生产），缺失会启动失败
AUTH_SECRET=replace-with-openssl-rand-hex-32

# 管理员用户名列表，逗号分隔；匹配 username 的用户首次登录会被标记为 admin
# 可选
ADMIN_USERNAMES=admin

# ---------- 数据库 ----------
# PostgreSQL 连接串
# 必需
DATABASE_URL=postgresql://user:password@localhost:5433/zhuifanhub

# ---------- 对象存储 (S3 兼容) ----------
# 用于封面图 / 头像上传；支持 AWS S3、Cloudflare R2、阿里云 OSS、腾讯 COS 等
# 必需（启用上传时）
S3_ENDPOINT=https://s3.example.com
S3_REGION=auto
S3_BUCKET=zhuifanhub
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# 对象公开访问基地址，前端 img src 会拼在 key 前面；缺省时用 {endpoint}/{bucket}
# 可选
# S3_PUBLIC_BASE=https://cdn.zhuifanhub.com
